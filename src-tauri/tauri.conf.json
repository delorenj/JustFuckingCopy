  "productName": "JustFuckingCopy",
  "version": "0.1.0",
  "identifier": "com.justfuckingcopy.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
